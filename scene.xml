<mujoco model="THex_Robot">
    <option timestep="0.01" gravity="0 0 -9.81"/>
    
    <compiler angle="radian"/>

    <default>
        <joint damping="0.5" armature="0.01"/>
        <geom solimp="0.9 0.95 0.001" solref="0.02 1"/>
    </default>

    <asset>
        <texture type="2d" name="grid" builtin="checker" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3" width="300" height="300"/>
        <material name="gridmat" texture="grid" texrepeat="5 5"/>
    </asset>

    <worldbody>
        <light pos="0 0 5" dir="0 0 -1" directional="true"/>
        
        <geom name="floor_visual" type="plane" size="5 5 0.1" material="gridmat" group="1" contype="0" conaffinity="0"/>
        
        <geom name="floor_collision" type="plane" size="5 5 0.1" friction="0.7 0.005 0.0001" rgba="0 0 0 0" group="0" contype="1" conaffinity="1"/>

        <geom name="support_stand" type="box" size="0.04 0.06 0.1" friction="0.7 0.005 0.0001" pos="0 0 0" group="1" contype="1" conaffinity="0" rgba="0.8 0.2 0.2 1"/>
    </worldbody>

    <include file="models/robot_model/robot.xml"/>
</mujoco>