<mujoco model="THex_Robot">
    <!-- simulation frequency 100Hz -->
    <option timestep="0.01" gravity="0 0 -9.81"/>
    <compiler angle="radian"/>

    <default>
        <!-- damping - friction; stabilize and prevent unrealistic oscillations; dissipates energy gradually -->
        <!-- actuator inertia; motor response more realistic; slower to accelerate/decelerate -->
        <joint damping="0.5" armature="0.01"/>

        <!-- solimp: contact between objects: 0.9 – how hard objects push back, 0.95 – friction loss coefficient, 0.001 – penetration tolerance -->
        <!-- solref: 0.02 – time constant for contact resolution, 1 – Stiffness damping ratio -->
        <geom solimp="0.9 0.95 0.001" solref="0.02 1"/>
    </default>

    <asset>
        <!-- size = (length, width, height, terrain vertical shift to avoid -ve offset) -->
        <hfield name="rough_terrain" nrow="100" ncol="10" size="0.5 4 0.06 0.06"/>
    </asset>

    <worldbody>
        <light pos="0 0 5" dir="0 0 -1" directional="true"/>

        <geom name="terrain_geom" type="hfield" hfield="rough_terrain" pos="0 3.7 0" friction="0.7 0.005 0.0001" contype="1" conaffinity="1" rgba="0 0 0 0"/>
        <geom name="terrain_visual" type="hfield" hfield="rough_terrain" pos="0 3.7 0" group="1" contype="0" conaffinity="0" rgba="0.6 0.5 0.4 1"/>
        
        <geom name="wall_back" type="box" pos="0 -0.3 0.5" size="0.5 0.05 1" rgba="0 0 0 0" group="1" contype="1" conaffinity="1"/>
        
        <geom name="wall_front" type="box" pos="0 7.7 0.5" size="0.5 0.05 1" rgba="0 0 0 0" group="1" contype="1" conaffinity="1"/>
        
        <geom name="wall_left" type="box" pos="-0.5 3.7 0.5" size="0.05 4 1" rgba="0 0 0 0" group="1" contype="1" conaffinity="1"/>
        
        <geom name="wall_right" type="box" pos="0.5 3.7 0.5" size="0.05 4 1" rgba="0 0 0 0" group="1" contype="1" conaffinity="1"/>
        
    </worldbody>

    <include file="models/robot_model/robot.xml"/>
</mujoco>